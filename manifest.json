{
  "manifest_version": 3,
  "name": "ApplyPilot",
  "description": "Job application autofill with local semantic matching, memory review, and action planning.",
  "version": "0.5.2",
  "permissions": ["activeTab", "storage", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "ApplyPilot",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["mainWorldBridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "aiSemanticMatcher.js",
        "formScanner.js",
        "formActions.js",
        "formAutofillAgent.js",
        "siteAdapters.js",
        "contentScriptV2.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "world": "ISOLATED"
    }
  ]
}
