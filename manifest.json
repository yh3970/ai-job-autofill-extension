{
  "manifest_version": 3,
  "name": "ApplyPilot",
  "description": "Job application autofill with AI resume parsing, local semantic matching, memory review, and action planning.",
  "version": "0.5.0",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "ApplyPilot",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["aiSemanticMatcher.js", "contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
